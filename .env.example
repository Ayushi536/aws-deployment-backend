# .env.example
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Server
PORT=3000
NODE_ENV=production

# ── AIMS Incident API (aimsIncident.js, used by incidentNotifier.js) ──
# Same values used in the mongo-backup-repo — must match.
AIMS_BASE_URL=https://aims.erpica.in/api/v1/public/incidents
AIMS_API_KEY=paste_your_real_or_test_key_here

# ── Watchdog (watchdog.js) ─────────────────────────────────────
BACKEND_HEALTH_URL=https://your-backend-domain/health
FRONTEND_URL=https://aims.erpica.in
CHECK_INTERVAL_MINUTES=5

# ── Backup heartbeat check (watchdog.js, reads what backup-s3.js wrote) ──
# Must match the mongo-backup-repo's S3_BUCKET_NAME/AWS_REGION exactly.
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=ap-south-1
HEARTBEAT_STALE_AFTER_HOURS=36
# AWS credentials picked up automatically via IAM role on EC2; if running
# locally also set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
